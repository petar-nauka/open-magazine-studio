# Supabase project credentials — copy this file to ".env" and fill in your values.
# Find them in your Supabase dashboard: Settings -> API.
# IMPORTANT: use the PUBLIC "anon" key here, NEVER the "service_role" key.
# Variable names must start with VITE_ (Vite only exposes those to the front end).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
